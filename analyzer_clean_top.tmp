"""
TrueWriting Analyzer - Core Analysis Engine v2
Analyzes sent emails to generate a TW-0 writing profile.

Key capability: Phrase-level fingerprinting â€” captures HOW the user
expresses concepts, not just what they write about. This is the
foundation for authentic AI voice reproduction.

Supports:
  - .mbox files (Gmail Takeout, Thunderbird export, Outlook export)
  - .eml files (individual or directory of)

Output: TW-0 profile as JSON including phrase fingerprint data
        ready for embedding into a vector DB.
"""

import mailbox
import email
import os
import re
import json
import math
import sys
from collections import Counter, defaultdict
from datetime import datetime, timedelta
from email.utils import parseaddr, parsedate_to_datetime

import textstat
import nltk
from nltk.tokenize import sent_tokenize, word_tokenize
from nltk.corpus import stopwords
