# Enron Collector — environment template
# Copy to .env locally; Railway sets DATABASE_URL automatically when you attach
# the Postgres plugin, so you typically don't set it by hand there.

# Postgres connection (REQUIRED). Railway Postgres plugin auto-populates this.
DATABASE_URL=postgresql://user:password@host:port/dbname

# Override the corpus URL if you want to pin a mirror. Default is CMU canonical.
# ENRON_TAR_URL=https://www.cs.cmu.edu/~enron/enron_mail_20150507.tar.gz

# Cap sent emails per mailbox. 500 is enough for CPP training for almost any writer.
# Top 10 senders (Lay, Skilling, Kitchen, etc.) have far more; cap keeps storage sane.
PER_WRITER_CAP=500

# Set to "true" to wipe the emails table before ingest. Useful for re-runs.
TRUNCATE_FIRST=false

# Progress log cadence.
LOG_EVERY=500
