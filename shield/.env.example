# ═══════════════════════════════════════════════════════════
# TrueWriting Shield - Configuration (MSP Edition)
# Copy to .env and fill in your values
# ═══════════════════════════════════════════════════════════

# ── Shield Service ───────────────────────────────────────
SHIELD_PORT=8300
SHIELD_DB_PATH=shield.db

# ── TrueWriting API (CPP generation) ────────────────────
TRUEWRITING_API_URL=http://localhost:8200

# ── Default Scoring Thresholds ──────────────────────────
# These are system defaults. Each distributor, reseller,
# tenant, and security group can override these.
SCORE_THRESHOLD_WARN=0.35
SCORE_THRESHOLD_HOLD=0.55

# ── Default DLP Settings ────────────────────────────────
DLP_MIN_CONFIDENCE=medium
DLP_ACTION=warn

# ── Note on M365 Credentials ────────────────────────────
# Tenant credentials are NOT stored here. They are stored
# per-tenant in the database, entered via the admin API:
#
#   POST /admin/tenants
#   {
#     "reseller_id": 1,
#     "name": "Acme Corp",
#     "domain": "acmecorp.com",
#     "ms_tenant_id": "...",
#     "ms_client_id": "...",
#     "ms_client_secret": "..."
#   }
#
# For multi-tenant app registration, ALL tenants can use
# the same client_id. Each tenant just needs their own
# tenant_id and admin consent grant.
