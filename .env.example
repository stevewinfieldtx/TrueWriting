# ==============================================================================
# Chimera Secured / TrueWriting — environment variables template
# ==============================================================================
# Copy this file to `.env` and fill in real values. The root .gitignore already
# protects `.env` and `.env.*` from ever being committed. Never paste real keys
# into this template file.
#
#   cp .env.example .env
#   nano .env   # or your editor of choice
#
# Any secrets below are placeholders, not real keys.
# ==============================================================================


# ------------------------------------------------------------------------------
# LLM provider — OpenRouter (REQUIRED for scorer, eval, and background generator)
# ------------------------------------------------------------------------------
# Used by: chimera_scorer.py, chimera_eval.py, background_generator_swarm.py
# Per project convention: always use OpenRouter for LLM calls.
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-REPLACE_WITH_REAL_KEY
# The model the scorer defaults to. Common picks: anthropic/claude-sonnet-4.6,
# anthropic/claude-haiku-4.5, openai/gpt-4o, meta-llama/llama-3.3-70b-instruct.
OPENROUTER_MODEL_ID=anthropic/claude-sonnet-4.6


# ------------------------------------------------------------------------------
# ElevenLabs — verbal BEC warning (OPTIONAL, planned feature)
# ------------------------------------------------------------------------------
# When a high-confidence impersonation is detected, synthesize a spoken warning
# to play to the recipient. No other BEC tool does this — a voice saying "this
# email's style does not match Nathan's — verify before acting" is more memorable
# than any banner. Only fires on HIGH-tier verdicts to avoid alert fatigue.
# Get a key at https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=
# The voice to use for warnings. Pick from https://elevenlabs.io/app/voice-library
# or use a default like "21m00Tcm4TlvDq8ikWAM" (Rachel).
ELEVENLABS_VOICE_ID=


# ------------------------------------------------------------------------------
# Chimera mailbox ingestion (REQUIRED for per-user CPP building against Hotmail)
# ------------------------------------------------------------------------------
# Hotmail/Outlook IMAP path — used by chimera_imap.py
CHIMERA_EMAIL=
CHIMERA_APP_PASSWORD=
# Hotmail/Outlook Graph/OAuth path — used by chimera_hotmail.py
# Register an Azure AD app: https://portal.azure.com -> App registrations
CHIMERA_CLIENT_ID=


# ------------------------------------------------------------------------------
# TrueWriting API service
# ------------------------------------------------------------------------------
# Used by: api.py (the TrueWriting CPP service, default port 8200)
TRUEWRITING_API_KEY=
TRUEWRITING_API_URL=http://localhost:8200
PORT=8200


# ------------------------------------------------------------------------------
# Shield service (Rain Networks / MSP-facing product)
# ------------------------------------------------------------------------------
# Used by: shield/service.py, shield/database.py, shield/cpp_builder.py
SHIELD_PORT=8300
SHIELD_DB_PATH=shield.db


# ------------------------------------------------------------------------------
# Pilot / deployment flags (forward-looking, not yet wired in)
# ------------------------------------------------------------------------------
# Run mode: "shadow" = log-only, no user-visible changes
#           "warn"   = add banner, no blocking
#           "enforce"= quarantine per policy
CHIMERA_MODE=shadow

# Per-pilot-phase FPR budget (real-email false-flag rate ceiling)
CHIMERA_FPR_BUDGET=0.03

# Enable the /explain endpoint in Shield. Leave on for pilots.
CHIMERA_EXPLAIN_ENABLED=true
